# Local default (SQLite)
DATABASE_URL=sqlite:///./saju_local.db

# If using local Postgres via docker-compose, switch to:
# DATABASE_URL=postgresql+psycopg2://saju:saju@localhost:5432/saju

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.0-flash
GEMINI_TIMEOUT_SECONDS=12
GEMINI_STREAM_TIMEOUT_SECONDS=120

# read 결과 캐시 on/off (false로 설정하면 매번 LLM 재호출)
CACHE_READS_ENABLED=true
